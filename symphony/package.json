{
  "name": "symphony",
  "version": "0.1.0",
  "description": "Orchestration service for coding agents — Symphony spec v1",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "symphony": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:local": "set -a; . ../.env; set +a; node dist/index.js --workflow ../WORKFLOW.md",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "liquidjs": "^10.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
